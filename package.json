{
  "name": "nexus",
  "version": "1.0.0",
  "description": "AI Cowork Mission Control -- The Cartographer",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "start": "cd server && node index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "concurrently": "^9.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
