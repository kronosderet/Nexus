    },
    {
      "id": 23,
      "project": "Nexus",
      "summary": "v1.5.1 Impact Analysis Engine. Four analysis modes built on the Knowledge Graph: (1) Blast Radius -- traces downstream impact of changing a decision via directed edge traversal, (2) Contradiction Detection -- finds conflicting decisions via superseded edges + keyword opposition pairs, (3) Centrality Analysis -- ranks most foundational decisions by connection count, (4) Structural Holes -- identifies weak cross-project links. CLI: nexus impact blast/contradictions/centrality/holes. 39 CLI commands.",
      "decisions": [
        "blast radius follows led_to+depends_on edges only",
        "contradiction uses keyword opposition pairs",
        "centrality is simple degree count",
        "structural holes analyzes cross-project edge density"
      ],
      "blockers": [],
      "files_touched": [],
